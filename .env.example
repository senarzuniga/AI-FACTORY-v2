# AI Factory v2 — Environment Variables
# Copy this file to .env and fill in your real values.
# The .env file is git-ignored and never committed.

# GitHub Personal Access Token (repo write + pull-requests)
GITHUB_TOKEN=ghp_your_token_here

# Target repository — options:
#   ALL              → analyse every repository you own (default)
#   owner/repo-name  → target a single specific repository
GITHUB_REPOSITORY=ALL

# Repositories to skip in ALL mode (comma-separated)
# SKIP_REPOS=owner/repo1,owner/repo2

# Optional owner/org scope in ALL mode (comma-separated)
# TARGET_OWNERS=senarzuniga,my-org

# Optional safety cap for how many repos are processed in one run
# MAX_REPOS_PER_RUN=25

# Set to false to also process forked repositories (default: skip forks)
# SKIP_FORKS=true

# OpenAI API key
OPENAI_API_KEY=sk-your_key_here

# Optional — override model/settings
# AI_MODEL=gpt-4o
# AI_MAX_TOKENS=4096
# AI_TEMPERATURE=0.3

# Optional — execution quality and safety gates
# MIN_BUSINESS_IMPACT=7.0
# MAX_TECHNICAL_RISK=4.0
# MIN_MAINTAINABILITY=5.0
# MIN_SCALABILITY=5.0
# MIN_COMPOSITE_SCORE=6.5
# MAX_COMPLEXITY=7.0
# MAX_FILES_PER_EXECUTION=5
# MAX_FILE_CHANGE_SIZE=20000
# MAX_TOTAL_CHANGE_SIZE=60000
# API_RETRY_ATTEMPTS=3
# API_RETRY_BACKOFF_SECONDS=1.0

# Set to "true" to analyse without creating a PR
# DRY_RUN=false
